# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tlgdb
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

# API (en local 4000 es habitual; en Docker el entrypoint usa TLO_LISTEN_PORT, p. ej. 4100)
PORT=4000
# Opcional; en contenedores el servidor usa 0.0.0.0 por defecto para aceptar el proxy
# LISTEN_HOST=0.0.0.0
NODE_ENV=development

# Logging: error | warn | info | debug (default info)
LOG_LEVEL=info

# Obligatorio en producción (login / refresh JWT)
JWT_SECRET=

# Uno o varios orígenes del front (coma). En desarrollo el API ya incluye 5173 y 8080 (Vite).
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Auth: JWT de acceso (Bearer). Prioridad: JWT_ACCESS_EXPIRES_SEC, JWT_EXPIRES_SEC, JWT_EXPIRES_IN (número = segundos, o 1h, 90m)
JWT_ACCESS_EXPIRES_SEC=3600
# Compatibilidad: JWT_EXPIRES_SEC=900  o  JWT_EXPIRES_IN=1h
# Refresh (POST /auth/refresh). Por defecto 7d si omites; puedes usar 604800 o 7d
JWT_REFRESH_EXPIRES_SEC=7d

# Initial admin (seed only)
SEED_ADMIN_EMAIL=admin@tlo.mx
SEED_ADMIN_PASSWORD=ChangeMe123!

# Archivos de documentación (operadores/unidades). En Docker: monta un volumen y usa UPLOAD_DIR=/app/uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tlo.mx

# Revisión diaria de vigencias (cron). TZ recomendado America/Mexico_City
CRON_DOC_CHECK=0 7 * * *
TZ=America/Mexico_City

# Sincronización automática de combustibles (descarga proveedor + importación)
# El job solo importa tickets; el prorrateo se confirma manualmente en Combustibles → Prorrateo.
FUEL_SYNC_ENABLED=false
# Por defecto 05:00 — antes de que revisen el resumen (ajusta a tu horario)
CRON_FUEL_SYNC=0 5 * * *
# Rango: desde inicio de mes o últimos N días (lo que sea más antiguo)
FUEL_SYNC_LOOKBACK_DAYS=35
# Proveedor HTTP (también configurable por tenant en PATCH /tenant/fuel)
FUEL_PROVIDER_URL=
FUEL_PROVIDER_USER=
FUEL_PROVIDER_PASSWORD=
# GET (default) o POST; nombres de query opcionales: FUEL_PROVIDER_QUERY_INICIO, FUEL_PROVIDER_QUERY_FIN
# FUEL_PROVIDER_METHOD=GET
# FUEL_PROVIDER_BEARER=
# FUEL_PROVIDER_TIMEOUT_MS=120000
# Pruebas locales: ruta a un .xlsx fijo en lugar de HTTP
# FUEL_SYNC_FILE_PATH=

# Carta Porte / fiscal (cifrado de tokens y contraseña CSD)
FISCAL_ENC_KEY=
PAC_PROVIDER=stub
# Sicofi DFWSR API base (sin /Comprobante40/...). tenant.pac_url tiene prioridad.
SICOFI_API_BASE_URL=https://demo.sicofi.com.mx/DFWSR/api
# Timeout HTTP al timbrar (ms)
SICOFI_TIMEOUT_MS=120000
