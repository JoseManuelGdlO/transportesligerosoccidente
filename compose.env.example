# Copiar a la raíz del repo como ".env" para docker compose:
#   cp compose.env.example .env
#
# La base MySQL ya existe en el servidor: rellena DB_* con host, usuario y contraseña reales.
# Si el API corre en Docker y MySQL está en el mismo host, prueba DB_HOST=host.docker.internal
# (Docker Desktop) o la IP interna / hostname que resuelva desde el contenedor.
#
# PUBLIC_WEB_ORIGIN y VITE_API_BASE_URL deben usar la IP o dominio que el NAVEGADOR ve.
#   PUBLIC_WEB_ORIGIN=http://203.0.113.10:8088
#   VITE_API_BASE_URL=http://203.0.113.10:5480/api/v1

# --- Puertos en el HOST ---
WEB_PUBLISH_PORT=8088
API_PUBLISH_PORT=5480

# --- Easy Panel / Docker (servicio api) ---
# El contenedor escucha en TLO_LISTEN_PORT (por defecto 4100). En el dominio del panel, destino HTTP = 4100.
# No pongas PORT=4000 en las variables del proyecto para este stack: pisa el puerto y el proxy devuelve 502.

# --- Origen del front para CORS (URL exacta del front en el navegador, con https) ---
# Ejemplo Easy Panel: https://prueba-tlo.TUPROJECTO.easypanel.host
# Varios orígenes: separados por coma. Puedes usar CORS_ORIGIN con el mismo formato.
PUBLIC_WEB_ORIGIN=https://tu-front.easypanel.host

# --- URL base de la API para el build del front (opcional: default del compose) ---
# En producción debe ser la URL pública de la API (navegador), con /api/v1
VITE_API_BASE_URL=http://127.0.0.1:5480/api/v1

# --- MySQL existente (fuera de Docker Compose) ---
# Desde el contenedor, 127.0.0.1 es el propio contenedor. Usa la IP/hostname del servidor
# donde está MySQL, o host.docker.internal si tu Docker lo soporta (p. ej. Docker Desktop).
DB_HOST=192.168.1.10
DB_PORT=3306
DB_NAME=tlgdb
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# --- API / auth (JWT_SECRET: obligatorio en serio; el default del compose solo evita fallo al parsear) ---
JWT_SECRET=reemplaza_por_un_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES_SEC=3600
JWT_REFRESH_EXPIRES_SEC=7d

# --- Seed del admin (al arrancar el contenedor api) ---
SEED_ADMIN_EMAIL=admin@tlo.mx
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Archivos adjuntos (catálogo documentación operador/unidad): carpeta en el HOST con persistencia ---
# Crea la carpeta en el servidor (p. ej. /srv/tlo/uploads) y monta el volumen en el servicio api.
UPLOADS_HOST_DIR=/srv/tlo/uploads
MAX_UPLOAD_MB=10

# --- Web Push (avisos de vencimiento en el navegador). Genera claves: npx web-push generate-vapid-keys ---
# Pega aquí la salida (public / private). Sin estas variables solo hay notificaciones in-app (campana).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tlo.mx

# Cron diario para revisar vigencias (expresión cron estándar). Hora según TZ.
CRON_DOC_CHECK=0 7 * * *
TZ=America/Mexico_City

# --- Sincronización automática de combustibles (job diario en el contenedor api) ---
# También configurable por tenant en PATCH /api/v1/tenant/fuel
FUEL_SYNC_ENABLED=false
CRON_FUEL_SYNC=0 5 * * *
FUEL_SYNC_LOOKBACK_DAYS=35
FUEL_PROVIDER_URL=
FUEL_PROVIDER_USER=
FUEL_PROVIDER_PASSWORD=
# FUEL_PROVIDER_METHOD=GET
# FUEL_PROVIDER_BEARER=
# FUEL_PROVIDER_TIMEOUT_MS=120000
# FUEL_PROVIDER_QUERY_INICIO=inicio
# FUEL_PROVIDER_QUERY_FIN=fin
# Pruebas: archivo fijo en lugar de HTTP (monta volumen si aplica)
# FUEL_SYNC_FILE_PATH=

# --- Carta Porte / fiscal (cifrado CSD y proveedor PAC) ---
FISCAL_ENC_KEY=
PAC_PROVIDER=stub
