# Copiar a la raíz del repo como ".env" para docker compose:
#   cp compose.env.example .env
#
# La base MySQL ya existe en el servidor: rellena DB_* con host, usuario y contraseña reales.
# Si el API corre en Docker y MySQL está en el mismo host, prueba DB_HOST=host.docker.internal
# (Docker Desktop) o la IP interna / hostname que resuelva desde el contenedor.
#
# PUBLIC_WEB_ORIGIN y VITE_API_BASE_URL deben usar la IP o dominio que el NAVEGADOR ve.
#   PUBLIC_WEB_ORIGIN=http://203.0.113.10:8088
#   VITE_API_BASE_URL=http://203.0.113.10:5480/api/v1

# --- Puertos en el HOST ---
WEB_PUBLISH_PORT=8088
API_PUBLISH_PORT=5480

# --- Origen del front para CORS ---
PUBLIC_WEB_ORIGIN=http://127.0.0.1:8088

# --- URL base de la API para el build del front (Vite; debe incluir /api/v1) ---
VITE_API_BASE_URL=http://127.0.0.1:5480/api/v1

# --- MySQL existente (fuera de Docker Compose) ---
# Desde el contenedor, 127.0.0.1 es el propio contenedor. Usa la IP/hostname del servidor
# donde está MySQL, o host.docker.internal si tu Docker lo soporta (p. ej. Docker Desktop).
DB_HOST=192.168.1.10
DB_PORT=3306
DB_NAME=tlgdb
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# --- API / auth ---
JWT_SECRET=reemplaza_por_un_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES_SEC=3600
JWT_REFRESH_EXPIRES_SEC=7d

# --- Seed del admin (al arrancar el contenedor api) ---
SEED_ADMIN_EMAIL=admin@tlo.mx
SEED_ADMIN_PASSWORD=ChangeMe123!
